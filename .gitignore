```gitignore
# =========================
# Node / Package Managers
# =========================
node_modules/
client/node_modules/
server/node_modules/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# Build Outputs
# =========================
dist/
build/
coverage/

# Expo / React Native
.expo/
.expo-shared/
*.expo

# Metro / React Native caches
.metro-health-check*

# =========================
# Environment Variables
# =========================
.env
.env.*
!.env.example

# dotenvx
.env.keys
.env.local
.env.*.local

# =========================
# Supabase
# =========================
supabase/.temp/
supabase/.branches/

# =========================
# OS Files
# =========================
.DS_Store
Thumbs.db

# =========================
# IDE / Editor
# =========================
.vscode/settings.json
.vscode/*.code-workspace

.idea/

# =========================
# Logs
# =========================
*.log

# =========================
# TypeScript
# =========================
*.tsbuildinfo

# =========================
# Misc
# =========================
tmp/
temp/
```
